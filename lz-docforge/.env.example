# =============================
# DocForge Local Configuration
# =============================
#
# Copy this file to `.env` and modify values as needed:
# cp .env.example .env

# Generic API endpoint override for VLM calls.
DOCLING_VLM_API_URL=http://127.0.0.1:11434/v1/chat/completions

# Engine-specific endpoint overrides.
DOCLING_VLM_OLLAMA_URL=http://127.0.0.1:11434/v1/chat/completions
DOCLING_VLM_LMSTUDIO_URL=http://127.0.0.1:1234/v1/chat/completions
DOCLING_VLM_OPENAI_URL=https://api.openai.com/v1/chat/completions

# Runtime and cache settings.
DOCLING_CACHE_DIR=/tmp/docforge-cache
DOCLING_ARTIFACTS_PATH=/tmp/docforge-artifacts

# Actor and serve settings.
DOCLING_SERVE_API_ENDPOINT=http://127.0.0.1:5001/v1alpha/convert/source
DOCLING_ACTOR_LOG_KEY=DOCFORGE_LOG
DOCLING_ACTOR_MANIFEST_KEY=OUTPUT_MANIFEST
